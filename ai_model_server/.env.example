# Example environment variables for AI Model Server
# Copy this file to .env and update with your actual values

# Server Configuration
HOST=0.0.0.0
PORT=8001

# Model Configuration
MODEL_PATH=./models/best.pt
MODEL_NAME=yolov8-custom

# Development mode
ENVIRONMENT=development

# HuggingFace token (for legacy IndicConformer model)
HUGGING_FACE_HUB_TOKEN=

# --- STT Provider Configuration ---
# STT Provider: "sarvam" (cloud API, default) or "legacy" (local Whisper + IndicConformer)
STT_PROVIDER=sarvam

# Sarvam AI API Key (required when STT_PROVIDER=sarvam)
# Get from: https://dashboard.sarvam.ai/
SARVAM_API_KEY=

# Whether to fallback to legacy STT if Sarvam fails or returns low confidence (default: true)
SARVAM_FALLBACK_TO_LEGACY=true

# Minimum confidence threshold to accept Sarvam result without fallback (default: 0.7)
SARVAM_CONFIDENCE_THRESHOLD=0.7