# SewaSetu Backend Environment Variables for Render Deployment
# IMPORTANT: This is an EXAMPLE file. Copy to .env and fill in your actual values.
# DO NOT commit your actual credentials to Git!

# AWS Credentials (Get these from AWS IAM Console)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-1

# Supabase Configuration (Get these from Supabase Dashboard)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# JWT Secret Key (Generate a strong random string)
API_SECRET_KEY=your_random_secret_key_here

# AI API URL - Leave empty if using integrated AWS Bedrock
AI_API_URL=

# ============================================================================
# HOW TO USE FOR RENDER DEPLOYMENT:
# ============================================================================
# 1. Go to Render Dashboard → Your Service → Environment
# 2. Add each variable above (use your actual values, not these placeholders)
# 3. Render will automatically load these as environment variables
# 4. The backend reads them using os.getenv()
# 
# DO NOT copy your actual .env file to Git - keep secrets secure!
# ============================================================================
