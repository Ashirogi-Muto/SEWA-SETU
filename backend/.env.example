# Backend Environment Variables
# Copy this file to .env and update with your actual values

# Supabase Configuration (DO NOT commit real values)
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# Security Configuration
API_SECRET_KEY=generate_a_strong_secret_key_minimum_32_characters
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# AI Model Server
AI_API_URL=http://127.0.0.1:8001/api/classify

# AWS Configuration (Amazon AI for Bharat Hackathon)
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-1

# IMPORTANT SECURITY NOTES:
# 1. Never commit the actual .env file to version control
# 2. Use strong, randomly generated API_SECRET_KEY (min 32 characters)
# 3. Restrict ALLOWED_ORIGINS to only necessary domains
# 4. Use environment-specific configurations for production
# 5. Keep AWS credentials secure and never share them publicly