# ==============================================================
# SewaSetu Backend Environment Variables
# Copy this file to .env and update with your actual values
# ==============================================================

AI_TIMEOUT=3.0

# Database (default works for local PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sewasetu

# Security
API_SECRET_KEY=generate_a_strong_secret_key_minimum_32_characters
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3005,http://localhost:3006

# AI Model Server
AI_SERVER_URL=http://127.0.0.1:8003/api/classify
AI_SERVER_BASE_URL=http://127.0.0.1:8003

# Operational
DEMO_MODE=false
DEMO_AUTH_ENABLED=true  # Set to false in production