# ============================================================================
# SEWASETU PRODUCTION ENVIRONMENT VARIABLES
# ============================================================================

# ============================================================================
# SEWASETU PRODUCTION ENVIRONMENT
# ============================================================================

# Database
DATABASE_URL="file:./dev.db"

# ============================================================================
# AI SERVICES - PRODUCTION
# Get API keys from:
# - Sarvam: https://www.sarvam.ai/
# - Cloudflare: https://dash.cloudflare.com/
# - Groq: https://console.groq.com/
# ============================================================================

# Sarvam STT (Speech-to-Text) - Hindi/English
# Get from: https://www.sarvam.ai/
SARVAM_API_KEY=

# Cloudflare AI (Vision - Llama 3.2 11B)
# Get from: https://dash.cloudflare.com/ → AI → Get Started
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_AI_TOKEN=

# Groq (Reasoning - Llama 3.1 70B)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=

# ============================================================================
# FILE STORAGE - SUPABASE
# Get from https://supabase.com/ → Project Settings → API
# ============================================================================

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ============================================================================
# NOTES:
# - Without API keys, the app uses intelligent fallback (mock responses)
# - Supabase is optional - files will use mock URLs without it
# - All AI services work independently - partial configuration supported
# ============================================================================
